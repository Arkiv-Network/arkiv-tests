# Copy to .env. Host ports are offset from the prod --dev sequencer
# (8545/8546/6160) so both stacks can run side by side.
RPC_PORT=18545
WS_PORT=18546
METRICS_PORT=16160
BEACON_HTTP_PORT=15052

# Block proposer fee recipient.
FEE_RECIPIENT=0x484ff82f1665C4C1BF3ce595F2925A105ec5BBa8

# Execution-layer knobs (same as the prod --dev setup). Change + recreate the
# reth service to apply; the chain is preserved.
BLOCK_GAS_LIMIT=30000000
# TXPOOL_MIN_PRIORITY_FEE=1000000000
# TXPOOL_MIN_PROTOCOL_FEE=10000000
