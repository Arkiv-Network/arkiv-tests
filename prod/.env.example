# Copy to .env. Host ports for the prod PoS stack.
RPC_PORT=8545
WS_PORT=8546
METRICS_PORT=6160
BEACON_HTTP_PORT=5052

# Block proposer fee recipient.
FEE_RECIPIENT=0x484ff82f1665C4C1BF3ce595F2925A105ec5BBa8

# Execution-layer knobs (same as the prod --dev setup). Change + recreate the
# reth service to apply; the chain is preserved.
BLOCK_GAS_LIMIT=30000000
