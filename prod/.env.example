# Copy this file to .env and fill in production values before deployment.
# Generate a mnemonic with:
#   ./generate_mnemonic.sh

DEV_MNEMONIC="replace with production mnemonic"

# Use the first address derived from DEV_MNEMONIC unless you intentionally choose
# a different signer/operator address.
PURE_RETH_SIGNER_ADDRESS=0x0000000000000000000000000000000000000000

CHAIN_ID=42069
BLOCK_TIME_SECONDS=2
# Block size: target gas limit per block (-> --builder.gaslimit). Pinning this
# also stops the dev-mode gas-limit auto-creep.
BLOCK_GAS_LIMIT=30000000
PURE_RETH_PREFUND_ETH=10000000

# Optional fee controls, in wei. Leave unset for reth defaults.
# Change a value, then: docker compose up -d --force-recreate sequencer
# (the chain/datadir is preserved across the restart).
#   Minimum priority fee a tx needs to be accepted into the pool:
# TXPOOL_MIN_PRIORITY_FEE=1000000000
#   Minimum protocol base fee floor:
# TXPOOL_MIN_PROTOCOL_FEE=10000000

RPC_PORT=8545
WS_PORT=8546
METRICS_PORT=6160

ARKIV_RETH_TAG=v0.1.0-pure-0
