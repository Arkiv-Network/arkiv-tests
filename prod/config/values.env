# ethereum-genesis-generator config for the Arkiv single-validator PoS devnet.
# Forks top out at Electra/Prague (Deneb+Electra active at genesis).
# Fulu/Osaka are intentionally disabled (far-future epoch).

CHAIN_ID=42069
PRESET_BASE=mainnet

# Single validator. The validator itself is injected from VALIDATOR_ADDRESS via
# config/additional-validators.txt during ./generate.sh. This mnemonic is now
# only used by ethereum-genesis-generator for execution-layer prefunded accounts.
NUMBER_OF_VALIDATORS=1
EL_AND_CL_MNEMONIC="style insect tray body company scan annual rebuild rely crazy patient anger"

# Timing. 6s slots: a real CL has per-slot overhead, so this is a safer starting
# point than the dev chain's 2s. Tune down once it's proven stable.
SLOT_DURATION_IN_SECONDS=6
GENESIS_DELAY=20

# Fork schedule: everything through Electra at genesis, Fulu/Osaka off.
ALTAIR_FORK_EPOCH=0
BELLATRIX_FORK_EPOCH=0
CAPELLA_FORK_EPOCH=0
DENEB_FORK_EPOCH=0
ELECTRA_FORK_EPOCH=0
FULU_FORK_EPOCH=18446744073709551615
GLOAS_FORK_EPOCH=18446744073709551615
